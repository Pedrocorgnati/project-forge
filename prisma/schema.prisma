// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum ProjectStatus {
  BRIEFING
  ESTIMATION
  APPROVED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum UserRole {
  SOCIO
  PM
  DEV
  CLIENTE
}

enum ClientAccessStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum DocumentType {
  PRD
  CHANGE_ORDER
  ESTIMATE
  DELIVERY
}

enum DocumentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  OBSOLETE
}

enum EstimateStatus {
  GENERATING
  READY
  ARCHIVED
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum TaskPriority {
  P0
  P1
  P2
  P3
}

enum ScopeResult {
  VALID
  INVALID
  PARTIAL
  NEEDS_REVIEW
}

enum ScopeAlertType {
  SCOPE_CREEP
  OUT_OF_SCOPE
  DUPLICATE
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  DISMISSED
}

enum ChangeOrderStatus {
  DRAFT
  SENT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXPIRED
}

enum AlertTier {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalAction {
  APPROVED
  REJECTED
  CLARIFICATION_REQUESTED
}

enum IndexationStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  FAILED
}

enum BriefStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PRDStatus {
  GENERATING // Claude CLI gerando (temporário)
  READY // Gerado com sucesso
  ERROR // Falha na geração — mantido para auditoria
}

enum PeriodType {
  WEEKLY
  MONTHLY
  FULL
}

// ─────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────

model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users     User[]
  projects  Project[]
  costRates CostRate[]

  @@map("organizations")
}

// ─────────────────────────────────────────────
// USER (maps to Supabase auth.users)
// ─────────────────────────────────────────────

model User {
  id                 String    @id @db.Uuid // matches auth.users.id
  organizationId     String    @map("organization_id") @db.Uuid
  email              String    @unique @db.VarChar(255)
  name               String    @db.VarChar(255)
  role               UserRole  @default(DEV)
  avatarUrl          String?   @map("avatar_url")
  mfaEnabled         Boolean   @default(false) @map("mfa_enabled")
  consentGivenAt     DateTime? @map("consent_given_at") @db.Timestamptz
  dataRetentionUntil DateTime? @map("data_retention_until") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  organization        Organization             @relation(fields: [organizationId], references: [id])
  projectMembers      ProjectMember[]
  documents           Document[]               @relation("DocumentCreator")
  documentVersions    DocumentVersion[]        @relation("DocumentVersionCreator")
  estimates           Estimate[]
  estimateVersions    EstimateVersion[]        @relation("EstimateVersionChanger")
  assignedTasks       Task[]                   @relation("TaskAssignee")
  createdTasks        Task[]                   @relation("TaskCreator")
  baselineCreations   ScopeBaseline[]          @relation("BaselineCreator")
  timesheets          TimesheetEntry[]
  approvalLogs        ApprovalLog[]
  approvalRequestsMade ApprovalRequest[]        @relation("ApprovalRequester")
  notifications       Notification[]
  notificationPrefs   NotificationPreference[]
  auditLogs           AuditLog[]
  changeOrders        ChangeOrder[]
  ragQueries          RAGQuery[]
  dismissedScopeAlerts ScopeAlert[]             @relation("ScopeAlertDismisser")
  costConfigsCreated  CostConfig[]             @relation("CostConfigCreator")
  costOverrides       CostOverride[]           @relation("CostOverrideUser")
  invitedClientAccesses ClientAccess[]         @relation("InvitedBy")

  @@index([organizationId], name: "IDX_users_organization")
  @@map("users")
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────

model Project {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String        @db.VarChar(255)
  slug           String        @db.VarChar(100)
  status         ProjectStatus @default(BRIEFING)
  revenue        Decimal?      @db.Decimal(12, 2)
  currency       String        @default("BRL") @db.VarChar(3)
  description    String?
  /** Taxa horária base do projeto (BRL/h) — usada para calcular impactCost das COs */
  hourlyRate     Decimal       @default(210) @map("hourly_rate") @db.Decimal(10, 2)
  /** Horas originais do contrato sem Change Orders */
  baseHours      Decimal       @default(0) @map("base_hours") @db.Decimal(10, 2)
  /** Horas totais do projeto = baseHours + sum(impactHours de COs APPROVED) */
  totalHours     Decimal       @default(0) @map("total_hours") @db.Decimal(10, 2)
  startedAt      DateTime?     @map("started_at") @db.Timestamptz
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization      @relation(fields: [organizationId], references: [id])
  members          ProjectMember[]
  brief            Brief?
  documents        Document[]
  estimates        Estimate[]
  tasks            Task[]
  changeOrders     ChangeOrder[]
  timesheets       TimesheetEntry[]
  ragIndex         RAGIndex?
  githubSync       GitHubSync?
  events           Event[]
  notifications    Notification[]
  projectCostRates ProjectCostRate[]
  costConfigs      CostConfig[]
  scopeAlerts      ScopeAlert[]
  scopeBaselines   ScopeBaseline[]
  profitReports    ProfitReport[]
  checkpoints      Checkpoint[]
  clientAccesses   ClientAccess[]
  approvalRequests ApprovalRequest[]
  clientFeedback   ClientFeedback[]
  emailLogs        EmailLog[]

  @@unique([organizationId, slug], name: "IDX_projects_slug")
  @@index([organizationId, status], name: "IDX_projects_org_status")
  @@map("projects")
}

// ─────────────────────────────────────────────
// PROJECT MEMBER
// ─────────────────────────────────────────────

model ProjectMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      UserRole
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─────────────────────────────────────────────
// BRIEF (1:1 per project)
// ─────────────────────────────────────────────

model Brief {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String      @unique @map("project_id") @db.Uuid
  status     BriefStatus @default(DRAFT)
  aiMetadata Json?       @map("ai_metadata") @db.JsonB
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  project      Project        @relation(fields: [projectId], references: [id])
  sessions     BriefSession[]
  prdDocuments PRDDocument[]
  estimates    Estimate[]

  @@map("briefs")
}

// ─────────────────────────────────────────────
// BRIEF SESSION (conversational interview)
// ─────────────────────────────────────────────

model BriefSession {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  briefId     String        @map("brief_id") @db.Uuid
  status      SessionStatus @default(ACTIVE)
  startedAt   DateTime      @default(now()) @map("started_at") @db.Timestamptz
  completedAt DateTime?     @map("completed_at") @db.Timestamptz
  cancelledAt DateTime?     @map("cancelled_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  brief     Brief           @relation(fields: [briefId], references: [id], onDelete: Cascade)
  questions BriefQuestion[]

  @@index([briefId], name: "IDX_brief_sessions_brief")
  @@map("brief_sessions")
}

// ─────────────────────────────────────────────
// BRIEF QUESTION (Q&A within a session)
// ─────────────────────────────────────────────

model BriefQuestion {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  order        Int
  questionText String    @map("question_text") @db.Text
  answerText   String?   @map("answer_text") @db.Text
  aiMetadata   Json?     @map("ai_metadata") @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  answeredAt   DateTime? @map("answered_at") @db.Timestamptz

  session BriefSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId], name: "IDX_brief_questions_session")
  @@index([sessionId, order], name: "IDX_brief_questions_session_order")
  @@map("brief_questions")
}

// ─────────────────────────────────────────────
// PRD DOCUMENT (append-only — imutável por design)
// ─────────────────────────────────────────────

model PRDDocument {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  briefId     String    @map("brief_id") @db.Uuid
  version     Int
  content     String    @db.Text
  generatedBy String    @map("generated_by") @db.Uuid // userId de quem gerou
  status      PRDStatus @default(GENERATING)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  // SEM updatedAt — design intencional: imutabilidade por append-only

  brief Brief @relation(fields: [briefId], references: [id], onDelete: Restrict)

  @@unique([briefId, version], name: "UQ_prd_documents_brief_version")
  @@index([briefId], name: "IDX_prd_documents_brief")
  @@index([briefId, version], name: "IDX_prd_documents_brief_version")
  @@map("prd_documents")
}

// ─────────────────────────────────────────────
// DOCUMENT ACCESS LOG (audit trail — imutável)
// ─────────────────────────────────────────────

model DocumentAccessLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  accessedBy String   @map("accessed_by") @db.Uuid // userId
  accessedAt DateTime @default(now()) @map("accessed_at") @db.Timestamptz
  action     String   @default("VIEW") @db.VarChar(20) // VIEW | EXPORT_MD | EXPORT_PDF
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)

  @@index([documentId], name: "IDX_doc_access_log_document")
  @@index([accessedBy], name: "IDX_doc_access_log_user")
  @@index([accessedAt], name: "IDX_doc_access_log_time")
  @@map("document_access_logs")
}

// ─────────────────────────────────────────────
// DOCUMENT (versionable)
// ─────────────────────────────────────────────

model Document {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String         @map("project_id") @db.Uuid
  createdBy      String         @map("created_by") @db.Uuid
  type           DocumentType
  title          String         @db.VarChar(255)
  status         DocumentStatus @default(DRAFT)
  currentVersion Int            @default(1) @map("current_version")
  slaDeadline    DateTime?      @map("sla_deadline") @db.Timestamptz
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  project          Project           @relation(fields: [projectId], references: [id])
  creator          User              @relation("DocumentCreator", fields: [createdBy], references: [id])
  versions         DocumentVersion[]
  approvalLogs     ApprovalLog[]
  changeOrders     ChangeOrder[]
  approvalRequests ApprovalRequest[]

  @@index([projectId, type], name: "IDX_documents_project_type")
  @@index([status], name: "IDX_documents_status")
  @@map("documents")
}

// ─────────────────────────────────────────────
// DOCUMENT VERSION (immutable)
// ─────────────────────────────────────────────

model DocumentVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId    String   @map("document_id") @db.Uuid
  createdBy     String   @map("created_by") @db.Uuid
  versionNumber Int      @map("version_number")
  content       String
  contentHash   String   @map("content_hash") @db.VarChar(64)
  metadata      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  creator  User     @relation("DocumentVersionCreator", fields: [createdBy], references: [id])

  @@unique([documentId, versionNumber])
  @@index([contentHash], name: "IDX_docver_hash")
  @@map("document_versions")
}

// ─────────────────────────────────────────────
// ESTIMATE
// ─────────────────────────────────────────────

model Estimate {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String          @map("project_id") @db.Uuid
  briefId       String?         @map("brief_id") @db.Uuid
  createdBy     String          @map("created_by") @db.Uuid
  version       Int             @default(1)
  totalMin      Decimal         @default(0) @map("total_min") @db.Decimal(10, 2)
  totalMax      Decimal         @default(0) @map("total_max") @db.Decimal(10, 2)
  currency      String          @default("BRL") @db.VarChar(3)
  confidence    ConfidenceLevel @default(LOW)
  status        EstimateStatus  @default(GENERATING)
  aiPrompt      String?         @map("ai_prompt") @db.Text
  aiRawResponse String?         @map("ai_raw_response") @db.Text
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  project        Project           @relation(fields: [projectId], references: [id])
  brief          Brief?            @relation(fields: [briefId], references: [id])
  creator        User              @relation(fields: [createdBy], references: [id])
  items          EstimateItem[]
  versions       EstimateVersion[]
  scopeBaselines ScopeBaseline[]

  @@index([projectId], name: "IDX_estimates_project")
  @@index([briefId], name: "IDX_estimates_brief")
  @@index([projectId, status], name: "IDX_estimates_project_status")
  @@map("estimates")
}

// ─────────────────────────────────────────────
// ESTIMATE ITEM (line items)
// ─────────────────────────────────────────────

model EstimateItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estimateId  String  @map("estimate_id") @db.Uuid
  category    String  @db.VarChar(100)
  description String  @db.Text
  hoursMin    Decimal @map("hours_min") @db.Decimal(8, 2)
  hoursMax    Decimal @map("hours_max") @db.Decimal(8, 2)
  hourlyRate  Decimal @default(210) @map("hourly_rate") @db.Decimal(10, 2)
  riskFactor  Decimal @default(1.0) @map("risk_factor") @db.Decimal(4, 2)
  costMin     Decimal @default(0) @map("cost_min") @db.Decimal(12, 2)
  costMax     Decimal @default(0) @map("cost_max") @db.Decimal(12, 2)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId], name: "IDX_estimate_items_estimate")
  @@index([estimateId, category], name: "IDX_estimate_items_category")
  @@map("estimate_items")
}

// ─────────────────────────────────────────────
// ESTIMATE VERSION (immutable snapshots)
// ─────────────────────────────────────────────

model EstimateVersion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estimateId String   @map("estimate_id") @db.Uuid
  version    Int
  snapshot   Json     @db.JsonB
  reason     String?  @db.Text
  changedBy  String   @map("changed_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  changer  User     @relation("EstimateVersionChanger", fields: [changedBy], references: [id])

  @@unique([estimateId, version])
  @@index([estimateId], name: "IDX_estimate_versions_estimate")
  @@map("estimate_versions")
}

// ─────────────────────────────────────────────
// BENCHMARK (historical project benchmarks)
// ─────────────────────────────────────────────

model Benchmark {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category    String   @db.VarChar(100)
  subcategory String?  @db.VarChar(100)
  avgHours    Decimal  @map("avg_hours") @db.Decimal(8, 2)
  p25         Decimal  @db.Decimal(8, 2)
  p75         Decimal  @db.Decimal(8, 2)
  source      String   @db.VarChar(100)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([category], name: "IDX_benchmarks_category")
  @@index([category, subcategory], name: "IDX_benchmarks_category_sub")
  @@map("benchmarks")
}

// ─────────────────────────────────────────────
// PROJECT CATEGORY (type/size metadata)
// ─────────────────────────────────────────────

model ProjectCategory {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String            @db.VarChar(100)
  slug          String            @unique @db.VarChar(100)
  parentId      String?           @map("parent_id") @db.Uuid
  parent        ProjectCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  subcategories ProjectCategory[] @relation("CategoryTree")

  @@map("project_categories")
}

// ─────────────────────────────────────────────
// TASK (Kanban)
// ─────────────────────────────────────────────

model Task {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String       @map("project_id") @db.Uuid
  assigneeId     String?      @map("assignee_id") @db.Uuid
  createdBy      String       @map("created_by") @db.Uuid
  title          String       @db.VarChar(500)
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(P2)
  labels         String[]     @default([])
  estimatedHours Decimal?     @map("estimated_hours") @db.Decimal(6, 2)
  actualHours    Decimal      @default(0) @map("actual_hours") @db.Decimal(10, 2)
  dueDate        DateTime?    @map("due_date") @db.Timestamptz
  position       Int          @default(0)
  scopeStatus    String?      @map("scope_status") @db.VarChar(20)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  project          Project           @relation(fields: [projectId], references: [id])
  assignee         User?             @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator          User              @relation("TaskCreator", fields: [createdBy], references: [id])
  scopeValidation  ScopeValidation?
  timesheets       TimesheetEntry[]
  changeOrderTasks ChangeOrderTask[]
  scopeAlerts      ScopeAlert[]

  @@index([projectId, status], name: "IDX_tasks_project_status")
  @@index([assigneeId], name: "IDX_tasks_assignee")
  @@index([projectId, status, position], name: "IDX_tasks_position")
  @@index([createdBy], name: "IDX_tasks_created_by")
  @@map("tasks")
}

// ─────────────────────────────────────────────
// SCOPE VALIDATION (1:1 per task, AI check)
// ─────────────────────────────────────────────

model ScopeValidation {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId              String      @unique @map("task_id") @db.Uuid
  result              ScopeResult
  similarityScore     Decimal     @map("similarity_score") @db.Decimal(5, 4)
  reasoning           String
  matchedRequirements Json        @default("[]") @map("matched_requirements") @db.JsonB
  validatedAt         DateTime    @default(now()) @map("validated_at") @db.Timestamptz

  task Task @relation(fields: [taskId], references: [id])

  @@map("scope_validations")
}

// ─────────────────────────────────────────────
// SCOPE ALERT (project-level or task-level)
// ─────────────────────────────────────────────

model ScopeAlert {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String          @map("project_id") @db.Uuid
  taskId        String          @map("task_id") @db.Uuid
  type          ScopeAlertType
  severity      AlertTier
  description   String
  aiRationale   String          @map("ai_rationale") @db.Text
  relatedTaskId String?         @map("related_task_id") @db.Uuid
  status        AlertStatus     @default(OPEN)
  dismissedBy   String?         @map("dismissed_by") @db.Uuid
  dismissedAt   DateTime?       @map("dismissed_at") @db.Timestamptz
  dismissReason String?         @map("dismiss_reason")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  project         Project   @relation(fields: [projectId], references: [id])
  task            Task      @relation(fields: [taskId], references: [id])
  dismissedByUser User?     @relation("ScopeAlertDismisser", fields: [dismissedBy], references: [id])

  @@index([projectId, status], name: "IDX_scope_alerts_project_status")
  @@index([projectId, severity], name: "IDX_scope_alerts_project_severity")
  @@map("scope_alerts")
}

// ─────────────────────────────────────────────
// SCOPE BASELINE (approved scope snapshot)
// ─────────────────────────────────────────────

model ScopeBaseline {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  estimateId  String?  @map("estimate_id") @db.Uuid
  createdBy   String?  @map("created_by") @db.Uuid
  name        String?  @db.VarChar(255)
  description String?
  tasks       Json     @db.JsonB
  features    Json     @db.JsonB
  snapshot    Json?    @db.JsonB   // task snapshot para diff (module-9)
  taskCount   Int      @default(0) @map("task_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  project  Project   @relation(fields: [projectId], references: [id])
  estimate Estimate? @relation(fields: [estimateId], references: [id])
  creator  User?     @relation("BaselineCreator", fields: [createdBy], references: [id])

  @@index([projectId], name: "IDX_scope_baselines_project")
  @@map("scope_baselines")
}

// ─────────────────────────────────────────────
// CHANGE ORDER
// ─────────────────────────────────────────────

model ChangeOrder {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String            @map("project_id") @db.Uuid
  createdBy       String            @map("created_by") @db.Uuid
  title           String            @db.VarChar(255)
  description     String
  status          ChangeOrderStatus @default(DRAFT)
  impactTier      AlertTier?        @map("impact_tier")
  hoursImpact     Decimal           @default(0) @map("hours_impact") @db.Decimal(8, 2)
  costImpact      Decimal           @default(0) @map("cost_impact") @db.Decimal(12, 2)
  scopeImpact     String?           @map("scope_impact")
  documentId      String?           @map("document_id") @db.Uuid
  sentAt          DateTime?         @map("sent_at") @db.Timestamptz
  resolvedAt      DateTime?         @map("resolved_at") @db.Timestamptz
  slaDeadline     DateTime?         @map("sla_deadline") @db.Timestamptz
  // ── Workflow de aprovação (module-11) ──
  approvedBy      String?           @map("approved_by") @db.Uuid
  approvedAt      DateTime?         @map("approved_at") @db.Timestamptz
  rejectedBy      String?           @map("rejected_by") @db.Uuid
  rejectedAt      DateTime?         @map("rejected_at") @db.Timestamptz
  rejectionReason String?           @map("rejection_reason") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  project  Project           @relation(fields: [projectId], references: [id])
  creator  User              @relation(fields: [createdBy], references: [id])
  document Document?         @relation(fields: [documentId], references: [id])
  tasks    ChangeOrderTask[]

  @@index([projectId, status], name: "IDX_change_orders_project_status")
  @@index([slaDeadline], name: "IDX_change_orders_sla")
  @@index([projectId, status], map: "IDX_change_orders_pending")
  @@map("change_orders")
