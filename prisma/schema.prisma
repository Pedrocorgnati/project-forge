// ─────────────────────────────────────────────
// RAG INDEX (1:1 per project)
// ─────────────────────────────────────────────

model RAGIndex {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String           @unique @map("project_id") @db.Uuid
  githubRepoUrl     String?          @map("github_repo_url")
  githubOwner       String?          @map("github_owner") @db.VarChar(100)
  githubRepo        String?          @map("github_repo") @db.VarChar(100)
  lastCommitSha     String?          @map("last_commit_sha") @db.VarChar(40)
  totalChunks       Int              @default(0) @map("total_chunks")
  indexedExtensions Json             @default("[]") @map("indexed_extensions") @db.JsonB
  indexationStatus  IndexationStatus @default(PENDING) @map("indexation_status")
  lastIndexedAt     DateTime?        @map("last_indexed_at") @db.Timestamptz
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz

  project      Project       @relation(fields: [projectId], references: [id])
  embeddings   Embedding[]
  ragDocuments RAGDocument[]
  ragQueries   RAGQuery[]

  @@map("rag_indexes")
}

// ─────────────────────────────────────────────
// RAG DOCUMENT (source files/chunks)
