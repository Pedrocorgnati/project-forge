// ─────────────────────────────────────────────
// APPROVAL REQUEST (client approval workflow)
// ─────────────────────────────────────────────

model ApprovalRequest {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  clientAccessId String    @map("client_access_id") @db.Uuid
  requestedBy    String    @map("requested_by") @db.Uuid
  type           String    @db.VarChar(30)           // DOCUMENT | MILESTONE | DELIVERABLE
  title          String    @db.VarChar(200)
  description    String
  documentId     String?   @map("document_id") @db.Uuid   // referência opcional a documento
  documentType   DocumentType?
  status         String    @default("PENDING") @db.VarChar(30)   // PENDING | APPROVED | REJECTED | EXPIRED
  slaDeadline    DateTime  @map("sla_deadline") @db.Timestamptz
  respondedAt    DateTime? @map("responded_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  project      Project           @relation(fields: [projectId], references: [id])
  clientAccess ClientAccess      @relation(fields: [clientAccessId], references: [id])
  requester    User              @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  document     Document?         @relation(fields: [documentId], references: [id])
  history      ApprovalHistory[]

  @@index([projectId, status, slaDeadline], name: "IDX_approval_requests_project_status_sla")
  @@index([clientAccessId], name: "IDX_approval_requests_client_access")
  @@map("approval_requests")
}

