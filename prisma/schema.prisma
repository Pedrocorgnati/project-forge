  embeddings Embedding[] @relation("RAGDocumentEmbeddings")

  @@index([ragIndexId], name: "IDX_rag_documents_index")
  @@map("rag_documents")
}

// ─────────────────────────────────────────────
// EMBEDDING (pgvector)
// ─────────────────────────────────────────────

model Embedding {
  id            String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ragIndexId    String                      @map("rag_index_id") @db.Uuid
  ragDocumentId String?                     @map("rag_document_id") @db.Uuid
  chunkText     String                      @map("chunk_text")
  embedding     Unsupported("vector(384)")?
  filePath      String                      @map("file_path")
