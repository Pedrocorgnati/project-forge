# ─────────────────────────────────────────────────────────
# Project Forge — Variáveis de Ambiente (Docker Dev) — EXEMPLO
# ─────────────────────────────────────────────────────────
# Copie para .env.docker e preencha com seus valores reais.
# Este arquivo SÃO contém segredos — pode ser versionado.
# ─────────────────────────────────────────────────────────

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
LOG_LEVEL=debug
ANALYZE=false

# ============================================
# APLICACAO
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ============================================
# SUPABASE (Obrigatório)
# Obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# BANCO DE DADOS - Prisma / PostgreSQL (via Supabase)
# Pooler URL (Transaction mode) para dev/runtime
# Direct URL para migrations
# ============================================
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# ============================================
# SEGURANCA
# Gere com: openssl rand -base64 32
# ============================================
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
CRON_SECRET=generate_with_openssl_rand_base64_32
INTERNAL_API_SECRET=generate_with_openssl_rand_hex_32

# ============================================
# GITHUB
# ============================================
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# ============================================
# EMAIL - Resend
# Obtenha em: https://resend.com/api-keys
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_WEBHOOK_SECRET=
RESEND_DOMAIN=projectforge.app

# ============================================
# AI / LLM - OpenAI
# Obtenha em: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-proj-your_openai_key
EMBEDDING_PROVIDER=openai

# ============================================
# SENTRY (Monitoramento de Erros)
# Obtenha em: https://sentry.io/settings/auth-tokens/
# ============================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=sua-org-slug
SENTRY_PROJECT=project-forge

# ============================================
# BUSINESS LOGIC
# ============================================
HOURLY_RATE_BRL=210
MARKET_MINIMUM_BRL=5000

# ============================================
# CONFIGURACAO INTERNA
# ============================================
DEFAULT_ORGANIZATION_ID=
