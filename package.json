{
  "name": "project-forge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:ci": "vitest run --coverage --reporter=default",
    "test:perf": "vitest run tests/performance/ --reporter=verbose",
    "test:load:smoke": "k6 run --env SCENARIO=smoke tests/load/run-all.js",
    "test:load": "k6 run tests/load/run-all.js",
    "test:load:stress": "k6 run --env SCENARIO=stress tests/load/run-all.js",
    "test:contracts": "vitest run --config vitest.config.contracts.ts",
    "test:contracts:watch": "vitest --config vitest.config.contracts.ts",
    "test:contracts:ci": "vitest run --config vitest.config.contracts.ts --reporter=verbose",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts",
    "test:integration:ci": "vitest run --config vitest.config.integration.ts --reporter=verbose",
    "test:all": "vitest run && vitest run --config vitest.config.contracts.ts && vitest run --config vitest.config.integration.ts",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "test:mutation:quick": "stryker run --mutate 'src/app/api/projects/[id]/change-orders/**/*.ts'",
    "analyze": "ANALYZE=true npm run build",
    "bundle:check": "node scripts/check-bundle-size.js",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:prod:build": "docker build -t project-forge:latest .",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^5.2.10",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "svix": "^1.89.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "madge": "^8.0.0",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "swagger-jsdoc": "^6.2.8",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "overrides": {
    "hono": "^4.12.7",
    "@hono/node-server": "^1.19.10",
    "effect": "^3.20.0",
    "lodash": "^4.17.23"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
