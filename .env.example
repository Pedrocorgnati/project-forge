# ─────────────────────────────────────────────────────────
# Project Forge — Variáveis de Ambiente (Exemplo)
# ─────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NÃO commite este arquivo com valores reais no .env
# ─────────────────────────────────────────────────────────

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
LOG_LEVEL=debug
ANALYZE=false

# ============================================
# APLICACAO
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# ============================================
# SUPABASE (Obrigatório)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# BANCO DE DADOS - Prisma / PostgreSQL
# ============================================
# Usar a connection pooler URL do Supabase para produção
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# URL direta para migrations (sem pooler)
DIRECT_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ============================================
# SEGURANCA (Auto-gerado)
# ============================================
# Secrets gerados automaticamente - NÃO compartilhe
# Para gerar novos: openssl rand -base64 32 (CRON_SECRET)
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
CRON_SECRET=gere-com-openssl-rand-base64-32
INTERNAL_API_SECRET=gere-com-openssl-rand-hex-32

# ============================================
# GITHUB WEBHOOK (HandoffAI)
# ============================================
# Secret com pelo menos 32 caracteres aleatórios
# Para obter: gere um novo secret no webhook do GitHub (Settings > Webhooks)
GITHUB_WEBHOOK_SECRET=

# ============================================
# GITHUB - Integração de Repositórios
# ============================================
# GitHub Personal Access Token
# Para obter:
#   1. Acesse https://github.com/settings/tokens
#   2. Generate new token (classic)
#   3. Selecione escopo "repo" (read access)
# Documentação: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens
GITHUB_TOKEN=

# ============================================
# EMAIL - Resend
# ============================================
# API Key do Resend para envio de emails
# Para obter sua propria chave:
#   1. Crie conta em https://resend.com
#   2. Va em API Keys > Create API Key
# Custo: Gratuito ate 3.000 emails/mes
# Documentacao: https://resend.com/docs
RESEND_API_KEY=re_

# Webhook secret do Resend (para validar eventos de entrega/bounce)
# Para obter:
#   1. Entre em https://resend.com/webhooks
#   2. Crie novo webhook apontando para /api/webhooks/resend
#   3. Copie o Signing Secret
# Documentacao: https://resend.com/docs/webhooks
RESEND_WEBHOOK_SECRET=

# Domínio de email para envio (deve ser verificado no Resend)
# Padrão: projectforge.app
RESEND_DOMAIN=projectforge.app

# ============================================
# AI / LLM - OpenAI
# ============================================
# API Key do OpenAI
# Usado para geração de embeddings (text-embedding-3-small, 384 dims)
# Para obter sua propria chave:
#   1. Crie conta em https://platform.openai.com
#   2. Va em API Keys > Create new secret key
# Custo: Pay-as-you-go. text-embedding-3-small: $0.02 por 1M tokens
# Documentacao: https://platform.openai.com/docs/api-reference/embeddings
OPENAI_API_KEY=sk-

# Tipo de provider de embeddings
# Valores suportados: openai
EMBEDDING_PROVIDER=openai

# ============================================
# SENTRY (Monitoramento de Erros)
# ============================================
# Para obter:
#   1. Crie conta em https://sentry.io
#   2. Crie um novo projeto (Next.js)
#   3. Em Settings > Projects > project-forge > Client Keys (DSN)
#
# DSN (Data Source Name) - apenas para servidor
# Formato: https://key@sentry.io/project-id
SENTRY_DSN=

# DSN público (cliente-side) - prefixado com NEXT_PUBLIC_
NEXT_PUBLIC_SENTRY_DSN=

# Auth Token do Sentry (para CI/CD, releases, source maps)
# Para obter:
#   1. Va em Settings > Auth Tokens
#   2. Create (scopes: project:releases, org:read)
SENTRY_AUTH_TOKEN=

# Slug da organização Sentry
SENTRY_ORG=sua-org-slug

# Slug do projeto Sentry
SENTRY_PROJECT=project-forge

# ============================================
# BUSINESS LOGIC - Taxas e Limites
# ============================================
# Taxa horária padrão em BRL (utilizada para cálculos de SLA)
# Padrão: 210 (R$ 210/hora)
HOURLY_RATE_BRL=210

# Valor mínimo de mercado em BRL (para validações)
# Padrão: 5000 (R$ 5.000)
MARKET_MINIMUM_BRL=5000

# ============================================
# CONFIGURAÇAO INTERNA
# ============================================
# ID padrão da organização para testes/dev
# Se deixado vazio, será usado o UUID da primeira organização criada
DEFAULT_ORGANIZATION_ID=
