{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/app/api/projects/**/change-orders/**/*.ts",
    "src/app/api/projects/**/scope-alerts/**/*.ts",
    "src/app/api/projects/**/pl-preview/**/*.ts",
    "src/app/api/projects/**/tasks/**/*.ts",
    "src/app/api/portal/**/*.ts",
    "src/app/api/notifications/**/*.ts",
    "src/app/api/cron/checkpoint-service/**/*.ts",
    "src/app/api/cron/recalculate-project-metrics/**/*.ts",
    "src/lib/services/**/*.ts",
    "src/lib/utils/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts",
    "!src/**/*.d.ts",
    "!src/__tests__/**",
    "!src/__mocks__/**"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 40
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "incremental": true,
  "incrementalFile": ".stryker-incremental.json",
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": false
  }
}
